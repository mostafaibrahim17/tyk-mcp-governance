# Copy to .env and fill in. `docker compose` reads this file automatically.

# Your OpenAI API key. Tyk injects it upstream so agents never see it.
OPENAI_API_KEY=sk-...

# Gateway admin secret — used for every /tyk/* admin API call (X-Tyk-Authorization).
TYK_SECRET=change-me-please

# Postgres (audit trail written by Tyk Pump).
POSTGRES_USER=tyk
POSTGRES_PASSWORD=tyk
POSTGRES_DB=tyk_analytics

# Pinned gateway version. The Go plugin MUST be compiled against this exact tag.
TYK_VERSION=v5.14.0
